/**
 * Implements hook_form_user_pass_alter() to change the layout of the page
 */
function qna_registration_form_user_pass_alter(array &$form, FormStateInterface $form_state, $form_id) {
  if (isset($form['name'])) {
    // Change the label
    $form['name']['#title'] = t('Your email');
  }
}

/**
 * Implements hook_theme() to register the account icon template
 */
function qna_registration_theme() {
  return [
    // Existing account icon template
    'qna_registration_account_icon' => [
      'template' => 'qna-registration-account-icon',
      'variables' => [
        'logged_in' => NULL,
        'login_url' => NULL,
        'items'     => [],
      ],
    ],

    // Page wrapper for /user/my-personal-data
    'qna_registration_personal_data' => [
      'template' => 'qna-registration-personal-data',
      'variables' => [
        'title'   => NULL,
        'body'    => NULL,
        'webform' => NULL,
      ],
    ],
  ];
}

/**
 * Implements hook_form_alter() to alter the webform 'qna_registration' when in update mode
 */
function qna_registration_form_alter(array &$form, FormStateInterface $form_state, $form_id) {
  $form_object = $form_state->getFormObject();

  // Only on webform submission forms
  if (!$form_object instanceof WebformSubmissionForm) {
    return;
  }

  /** @var \Drupal\webform\WebformSubmissionInterface $submission */
  $submission = $form_object->getEntity();

  // Only for the "qna_registration" webform
  if ($submission && $submission->getWebform()->id() == 'qna_registration') {
    $is_new = $submission->isNew();
    $form_state->set('is_update', !$is_new);

    // Prevent webform submission informations from being displayed
    foreach ($form as $key => &$element) {
      if (is_array($element) && isset($element['#type']) && $element['#type'] === 'webform_submission_information') {
        $element['#access'] = FALSE;
      }
    }
    unset($element);

    // Only in update mode
    if (!$submission->isNew()) {
      // Disable title field
      if (isset($form['elements']['identity']['flexbox']['title'])) {
        $form['elements']['identity']['flexbox']['title']['#disabled'] = TRUE;
        $form['elements']['identity']['flexbox']['title']['#attributes']['disabled'] = 'disabled';
      }

      // Disable date of birth field
      if (isset($form['elements']['identity']['flexbox']['date_of_birth'])) {
        $form['elements']['identity']['flexbox']['date_of_birth']['#disabled'] = TRUE;
        $form['elements']['identity']['flexbox']['date_of_birth']['#attributes']['disabled'] = 'disabled';
      }

      // Disable first name field
      if (isset($form['elements']['identity']['flexbox_01']['first_name'])) {
        $form['elements']['identity']['flexbox_01']['first_name']['#disabled'] = TRUE;
        $form['elements']['identity']['flexbox_01']['first_name']['#attributes']['disabled'] = 'disabled';
      }

      // Disable last name field
      if (isset($form['elements']['identity']['flexbox_01']['last_name'])) {
        $form['elements']['identity']['flexbox_01']['last_name']['#disabled'] = TRUE;
        $form['elements']['identity']['flexbox_01']['last_name']['#attributes']['disabled'] = 'disabled';
      }

      // Disable email field
      if (isset($form['elements']['identity']['flexbox_02']['email_address'])) {
        $form['elements']['identity']['flexbox_02']['email_address']['#disabled'] = TRUE;
        $form['elements']['identity']['flexbox_02']['email_address']['#attributes']['disabled'] = 'disabled';
      }

      // Disable country field
      if (isset($form['elements']['identity']['flexbox_02']['country'])) {
        $form['elements']['identity']['flexbox_02']['country']['#disabled'] = TRUE;
        $form['elements']['identity']['flexbox_02']['country']['#attributes']['disabled'] = 'disabled';
      }

      // Change submit button label
      $form['actions']['submit']['#value'] = t('Update my informations');

      // Add "Change my password" button
      $form['actions']['change_password'] = [
        '#type' => 'link',
        '#title' => t('Change my password'),
        '#url' => Url::fromRoute('entity.user.edit_form', ['user' => \Drupal::currentUser()->id()]),
        '#attributes' => [
          'class' => ['button', 'button--primary'],
        ],
        '#weight' => 101,
      ];
    }
  }
}
