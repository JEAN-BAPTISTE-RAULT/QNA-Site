<?php

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Url;
use Drupal\Core\Link;
use Drupal\webform\WebformSubmissionForm;

/**
 * Implements hook_mail()
 */
function qna_registration_mail($key, &$message, $params) {
  switch ($key) {
    case 'participant_accept':
      $message['subject'] = t('qna – Confirmation of your registration request');
      $message['body'][] = $params['message'];
      break;
    case 'participant_refuse':
      $message['subject'] = t('qna – Your registration request');
      $message['body'][] = $params['message'];
      break;
  }
}

/**
 * Implements hook_form_user_pass_reset_alter() to hide picture on password reset
 */
function qna_registration_form_user_pass_reset_alter(array &$form, FormStateInterface $form_state, $form_id) {
  if (isset($form['user_picture'])) {
    $form['user_picture']['#access'] = FALSE;
  }
}

/**
 * Implements hook_form_user_form_alter() to hide picture on user edit page
 */
function qna_registration_form_user_form_alter(array &$form, FormStateInterface $form_state, $form_id) {
  if (isset($form['user_picture'])) {
    $form['user_picture']['#access'] = FALSE;
  }
}

/**
 * Implements hook_form_user_login_form_alter() to change the layout of the page
 */
function qna_registration_form_user_login_form_alter(array &$form, FormStateInterface $form_state, $form_id) {
  // Remove the old "forgot_pass" button
  if (isset($form['actions']['forgot_pass'])) {
    unset($form['actions']['forgot_pass']);
  }

  // Title
  $form['login_title'] = [
    '#type' => 'markup',
    '#markup' => '<h2 class="user-login__title">Login</h2>',
    '#weight' => -100,
  ];

  // Username label
  if (isset($form['name'])) {
    $form['name']['#title'] = t('Your email');
  }

  // Password label + "Show/Hide password" toggle + "Forgot your password?" link
  if (isset($form['pass'])) {
    $form['pass']['#title'] = t('Your password');

    $forgot_link = Link::fromTextAndUrl(t('Forgot your password?'), Url::fromRoute('user.pass'))->toString();

    // Wrap the password input and place the toggle
    $form['pass']['#prefix'] = '<div class="password-container"><div class="password-with-eye">';
    $form['pass']['#suffix'] = '
        <div class="password-toggle-wrapper">
          <a href="#" class="password-toggle" aria-label="' . t('Show password') . '">' . t('Show password') . '</a>
        </div>
      </div>
      <div class="user-login__forgot">' . $forgot_link . '</div>
    </div>';
  }

  $image_url = \Drupal::service('file_url_generator')->generateString('public://login/login.png');

  // Wrap the form
  $existing_prefix = isset($form['#prefix']) ? $form['#prefix'] : '';
  $existing_suffix = isset($form['#suffix']) ? $form['#suffix'] : '';

  $form['#prefix'] = $existing_prefix .
    '<div class="login-layout">
       <div class="login-layout__left">';

  $form['#suffix'] = '</div>
       <div class="login-layout__right" role="img" aria-label="Login illustration">
         <img src="' . $image_url . '" alt="" />
       </div>
     </div>' . $existing_suffix;

  // Force redirect to homepage after successful login
  // $form['actions']['submit']['#submit'][] = 'qna_registration_user_login_redirect_submit';

  // Attach libraries: eye toggle behavior + layout styles
  $form['#attached']['library'][] = 'qna_registration/login_eye';
  $form['#attached']['library'][] = 'qna_registration/login_layout';
}

