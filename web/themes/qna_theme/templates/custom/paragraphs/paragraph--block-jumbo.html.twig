{%
  set classes = [
    'paragraph',
    'paragraph--type--' ~ paragraph.bundle|clean_class,
    view_mode ? 'paragraph--view-mode--' ~ view_mode|clean_class,
    not paragraph.isPublished() ? 'paragraph--unpublished'
  ]
%}
{% block paragraph %}
  <section{{ attributes.addClass(classes) }}>
    {% block content %}
      <div>
      <div class="d-flex">
        <div class="img-block">
            {{ content.field_image }}
            <h1>{{ paragraph.field_title.value }}</h1>
        </div>
        <div class="motif motif_primary motif_border"></div>
        </div>
        <div class="motif-mobile motif-mobile_primary motif-mobile_size"></div>

        <div class="text-block">
        <div>
            <h2>{{ paragraph.field_subtitle.value }}</h2>
        </div>
        <div>
          <p>{{ paragraph.field_description.value | raw }}</p>
        </div>
        {% if content.field_link is not empty %}
            <div>
              {% for key, value in content.field_link %}
                {% if key|first != '#' %}
                  {{ value }}
                {% endif %}
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>
    {% endblock %}
    </div>
  </section>
{% endblock paragraph %}