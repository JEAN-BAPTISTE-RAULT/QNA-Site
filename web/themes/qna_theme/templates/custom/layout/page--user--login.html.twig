<div class="layout-container">
  <header role="banner">
    {{ page.branding }}
    {{ page.header_nav }}
  </header>

  <main role="main">
    <a id="main-content" tabindex="-1"></a>{# link is in html.html.twig #}

    <div class="layout-content">
      {{ page.content }}
    </div>
  </main>

  <footer role="contentinfo">
    {{ page.footer_nav }}
  </footer>
</div>
