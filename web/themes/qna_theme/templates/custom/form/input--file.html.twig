{#
/**
 * @file
 * Theme override for an 'input' #type file form element.
 *
 * Available variables:
 * - attributes: A list of HTML attributes for the input element.
 * - children: Optional additional rendered elements.
 *
 * @see template_preprocess_input()
 */
#}
<div class="form-input-file">
  <label class="form-input-file__label">
    <input{{ attributes }} />{{ children }}
    <div class="form-input-file__button">{{ "Browse" | t }}</div>
    <div class="form-input-file__filename">{{ "No file selected" | t }}</div>
  </label>
</div>
