{%
  set classes = [
    'region',
    'region-' ~ region|clean_class,
  ]
%}
{% if content %}
	<div{{attributes.addClass(classes)}}>
		{{ content }}
	
    {# TMP #}
    <div class="paragraph--type--block-slideshow-stakeholders paragraph--type--block-slideshow-stakeholders-collections">
      <div class="d-flex justify-content-between align-items-center block-stakeholders__title">
        <h2>Les collections</h2>
        <div class="block-stakeholders__partners-link pc-partners-links">
          <a href="#">All collections</a>
          <i class="icon-arrow-right" aria-hidden="true"></i>
        </div>
      </div>
      <div class="swiper collections"
          slide-views="2.2"
          has-breakpoints="false">
        <div class="swiper-wrapper">
          {% for i in 0..3 %}
            <div class="swiper-slide collections-slide">
              <a class="collections-item d-flex" href="#">
                <div class="collections-image ratio ratio-1x1"><img src="https://placehold.co/600x400" alt></div>
                <div class="collections-text ratio ratio-1x1">
                  <div class="d-flex flex-column align-items-center justify-content-center text-center">
                    <span class="collections-title">Collections Antisémitisme, antijudaïsme et sionisme</span>
                    <span class="collections-link-label">Learn more</span>
                  </div>
                </div>
              </a>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
  {{ attach_library('neshama_theme/swiper') }}
{% endif %}
