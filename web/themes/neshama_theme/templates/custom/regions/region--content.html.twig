{%
  set classes = [
    'region',
    'region-' ~ region|clean_class,
  ]
%}
{% if content %}
	<div{{attributes.addClass(classes)}}>
		{{ content }}
	
    {# TMP #}
    
    <div class="swiper collections"
         slide-views="2.1">
      <div class="swiper-wrapper">
        {% for i in 0..3 %}
          <div class="swiper-slide collections-slide">
            <a class="collections-item d-flex" href="#">
              <div class="collections-image ratio ratio-1x1"><img src="https://placehold.co/600x400" alt></div>
              <div class="collections-text ratio ratio-1x1">
                <div class="d-flex flex-column align-items-center justify-content-center text-center">
                  <span class="collections-title">Collections Antisémitisme, antijudaïsme et sionisme</span>
                  <span class="collections-link-label">Learn more</span>
                </div>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
{% endif %}
